{
  "files.watcherExclude": {
    "**/.git/objects/**": true,
    "**/.git/subtree-cache/**": true,
    "**/.hg/store/**": true,
    ".flatpak/**": true,
    "_build/**": true
  },
  "clangd.arguments": [
    "--enable-config",
    "--compile-commands-dir=builddir"
  ],
  "mesonbuild.configureOnOpen": false,
  "mesonbuild.buildFolder": "_build",
  "mesonbuild.mesonPath": "${workspaceFolder}/.flatpak/meson.sh"
}